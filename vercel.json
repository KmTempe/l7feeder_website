{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run check",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/process-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path((?!@|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}