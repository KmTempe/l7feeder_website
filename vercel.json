{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run check",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/process-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://github.com https://avatars.githubusercontent.com; connect-src 'self' https://*.clarity.ms; frame-src https://snowflake.torproject.org; object-src 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path((?!@|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}