# Example environment variables for Vercel contact API
# NEVER commit real secrets to public repos!

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
CONTACT_RECEIVER=example@gmail.com
VITE_HOMELAB_STACK_DIAGRAM_URL=https://example.public.blob.vercel-storage.com/homelab/docker-compose-diagram.svg
