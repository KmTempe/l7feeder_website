# Example environment variables for local development and Vercel.
# Never commit real secrets.

# OTP email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Redis / Vercel KV compatible connection
REDIS_URL=rediss://default:password@host:6379
DEV_REDIS_URL=redis://localhost:6379

# LibreDesk message delivery
LIBREDESK_API_URL=https://support.example.com/api/v1
LIBREDESK_API_KEY=your_api_key
LIBREDESK_API_SECRET=your_api_secret
LIBREDESK_INBOX_ID=1
LIBREDESK_AGENT_ID=
LIBREDESK_TEAM_ID=
LIBREDESK_PRIORITY=Low
LIBREDESK_TAGS=l7f

# Protected queue processing endpoints
CRON_SECRET=replace_with_long_random_value
QUEUE_SECRET=replace_with_long_random_value

# Public frontend config. Values prefixed with VITE_ are exposed to the browser.
VITE_HOMELAB_STACK_DIAGRAM_URL=https://example.public.blob.vercel-storage.com/homelab/docker-compose-diagram.svg
VITE_STRESS_VIDEO_URL=
VITE_LIBREDESK_BASE_URL=https://support.example.com
VITE_LIBREDESK_INBOX_ID=
